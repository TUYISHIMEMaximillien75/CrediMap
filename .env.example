# ── CrediMap Backend Environment Variables ────────────────────────────────────
# Copy this file to .env and fill in your values before running the server.
# NEVER commit the actual .env file to version control.

# ── Database (MySQL) ──────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=credmap
DB_USER=root
DB_PASS=your_mysql_password_here

# ── Authentication ────────────────────────────────────────────────────────────
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret_string

# ── CORS ──────────────────────────────────────────────────────────────────────
# Development: http://localhost:5173 (Vite default)
# Production:  https://your-domain.com
FRONTEND_ORIGIN=http://localhost:5173

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
# NODE_ENV=production   ← uncomment for production deployment

# ── Notes ────────────────────────────────────────────────────────────────────
# In production:
#   - Set NODE_ENV=production (enables safe error messages in API responses)
#   - Use a cloud DB (e.g. PlanetScale, AWS RDS) and set DB_* accordingly
#   - Set FRONTEND_ORIGIN to your real deployed frontend URL
#   - Run migrations instead of sync(): npx sequelize-cli db:migrate

# ── Email / SMTP (optional) — for password reset & notifications ─────────────
# Leave blank to skip email sending (tokens will be logged to console)
# Dev: use Mailtrap.io (free)  |  Prod: use Gmail, SendGrid, Resend, etc.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="CrediMap <noreply@credmap.app>"

# ── Gmail example (use an App Password, not your main password) ───────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=youremail@gmail.com
# SMTP_PASS=your_16char_app_password
